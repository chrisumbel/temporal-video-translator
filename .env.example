# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=video-translator
TEMPORAL_WORKFLOW_ID=video-translator

# Per-stage queues with per-worker concurrency caps sized to Azure quotas
TEMPORAL_TRANSCRIBE_TASK_QUEUE=video-translator-transcribe
TEMPORAL_SUMMARIZE_TASK_QUEUE=video-translator-summarize
TEMPORAL_TRANSLATE_TASK_QUEUE=video-translator-translate
TEMPORAL_SCREENSHOT_TASK_QUEUE=video-translator-screenshot
MAX_CONCURRENT_TRANSCRIBE=3
MAX_CONCURRENT_SUMMARIZE=2
MAX_CONCURRENT_TRANSLATE=4
MAX_CONCURRENT_SCREENSHOT=2

# Azure resources. Keys are fetched at runtime via ARM listKeys, never stored here.
# dev: only try developer credentials (Azure CLI etc.), skipping the managed
# identity IMDS probe that times out off-cloud. Omit when deployed on Azure.
AZURE_TOKEN_CREDENTIALS=dev
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_RESOURCE_GROUP=temporal-video-translator
AZURE_LOCATION=eastus

# Azure AI Video Indexer (transcription)
VIDEO_INDEXER_ACCOUNT_NAME=tvt-video-indexer
VIDEO_INDEXER_ACCOUNT_ID=00000000-0000-0000-0000-000000000000

# Azure AI Translator (translations)
TRANSLATOR_ACCOUNT_NAME=tvt-translator
TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com

# Azure Blob Storage: public json results container, private videos staging container.
STORAGE_ACCOUNT_NAME=tvttranslations
STORAGE_CONTAINER=json
STORAGE_VIDEO_CONTAINER=videos
SCRATCH_SCREENSHOT_CONTAINER=scratchscreenshots
SCREENSHOT_CONTAINER=screenshots

# Azure OpenAI (summarization)
OPENAI_ACCOUNT_NAME=tvt-openai
OPENAI_ENDPOINT=https://tvt-openai.openai.azure.com
OPENAI_DEPLOYMENT=gpt-4o
PDF_CONTAINER=pdf
